# quick_create.py
import os

# 在agreements目录中运行此脚本
paths = [
    'parsers/__init__.py',
    'parsers/base_parser.py',
    'parsers/pdf_parser.py',
    'parsers/ocr_parser.py',
    'matchers/__init__.py',
    'matchers/customer_matcher.py',
    'matchers/agreement_matcher.py',
    'utils/__init__.py',
    'utils/file_utils.py',
    'utils/validation.py',
    'utils/constants.py',
    '__init__.py',
    'admin.py',
    'apps.py',
    'models.py',
    'views.py',
    'urls.py',
    'forms.py',
    'tests.py',
    'templates/agreements/.keep',
    'static/agreements/js/.keep',
    'static/agreements/css/.keep',
]

for path in paths:
    dir_path = os.path.dirname(path)
    if dir_path and not os.path.exists(dir_path):
        os.makedirs(dir_path, exist_ok=True)
    if not os.path.exists(path):
        with open(path, 'w', encoding='utf-8') as f:
            if path.endswith('.py'):
                f.write(f'# {os.path.basename(path)}\n\n')
        print(f'Created: {path}')

print('✅ 所有文件创建完成！')
