        print("       ...,")
        print("       'agreements',")
        print("   ]")
        print("\n2. 运行迁移:")
        print("   python manage.py makemigrations agreements")
        print("   python manage.py migrate")
        print("=" * 60)
    
    input("\n按Enter键退出...")


if __name__ == '__main__':
    main()
