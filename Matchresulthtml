<!-- templates/agreements/match_results.html -->
<div class="match-results">
    <h3>Matching Results for: <strong>{{ agreement.borrower_name }}</strong></h3>
    
    <div class="agreement-summary">
        <p>Agreement Amount: {{ agreement.facility_amount|floatformat:2 }} {{ agreement.currency }}</p>
        <p>Date: {{ agreement.agreement_date|date:"Y-m-d" }}</p>
        <p>Normalized Borrower Name: <code>{{ normalized_borrower }}</code></p>
    </div>
    
    {% if matches %}
    <div class="match-stats">
        Found {{ matches|length }} potential matches
    </div>
    
    <div class="customer-matches">
        {% for match in matches %}
        <div class="match-card">
            <div class="match-header">
                <div class="score-display">
                    <div class="score-value">{{ match.score }}%</div>
                    <div class="score-label">Match ({{ match.match_type }})</div>
                </div>
                <div class="customer-info">
                    <h4>{{ match.customer.name }}</h4>
                    <div class="customer-details">
                        <span>ID: {{ match.customer.customer_id }}</span>
                        <span>Group: {{ match.customer.master_group_id|default:"N/A" }}</span>
                    </div>
                </div>
            </div>
            
            <!-- 添加详细的对比信息 -->
            <div class="comparison-details">
                <h5>Comparison Details:</h5>
                <table class="comparison-table">
                    <thead>
                        <tr>
                            <th>Field</th>
                            <th>Original Value</th>
                            <th>Normalized Value</th>
                            <th>Match Score</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>Customer Name</td>
                            <td>{{ match.comparison_details.customer_original }}</td>
                            <td>{{ match.comparison_details.customer_normalized }}</td>
                            <td>{{ match.comparison_details.name_score }}%</td>
                        </tr>
                        {% if match.comparison_details.master_group_original %}
                        <tr>
                            <td>Master Group</td>
                            <td>{{ match.comparison_details.master_group_original }}</td>
                            <td>{{ match.comparison_details.master_group_normalized }}</td>
                            <td>{{ match.comparison_details.group_score }}%</td>
                        </tr>
                        {% endif %}
                    </tbody>
                </table>
            </div>
            
            <!-- 其他信息保持不变... -->
        </div>
        {% endfor %}
    </div>
    {% else %}
    <div class="no-matches">
        <p>No potential matches found for "{{ agreement.borrower_name }}"</p>
        <p>Suggestions:</p>
        <ul>
            <li>Check the borrower name spelling in the agreement</li>
            <li>Try alternative name variations</li>
            <li>Verify the customer exists in the system</li>
        </ul>
    </div>
    {% endif %}
</div>

<style>
.match-card {
    border: 1px solid #e0e0e0;
    border-radius: 8px;
    padding: 15px;
    margin-bottom: 15px;
    background: #f9f9f9;
}

.comparison-table {
    width: 100%;
    border-collapse: collapse;
    margin-top: 10px;
    font-size: 14px;
}

.comparison-table th, .comparison-table td {
    border: 1px solid #ddd;
    padding: 8px;
    text-align: left;
}

.comparison-table th {
    background-color: #f2f2f2;
}

.comparison-table tr:nth-child(even) {
    background-color: #f9f9f9;
}

.match-header {
    display: flex;
    align-items: center;
    margin-bottom: 10px;
}

.score-display {
    background: #4a90e2;
    color: white;
    border-radius: 50%;
    width: 60px;
    height: 60px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    margin-right: 15px;
}

.score-value {
    font-size: 18px;
    font-weight: bold;
}

.score-label {
    font-size: 10px;
    text-align: center;
}

.customer-info h4 {
    margin: 0;
    color: #333;
}

.customer-details {
    font-size: 13px;
    color: #666;
}

.select-btn {
    background: #5cb85c;
    color: white;
    border: none;
    padding: 8px 15px;
    border-radius: 4px;
    cursor: pointer;
    margin-top: 10px;
}

.no-matches {
    text-align: center;
    padding: 30px;
    color: #666;
}
</style>
