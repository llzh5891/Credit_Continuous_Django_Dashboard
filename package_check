#!/usr/bin/env python3
"""
依赖检查脚本
用于检查AI集成功能所需的Python依赖包
"""

import sys
import importlib
from importlib.metadata import version, PackageNotFoundError

def check_dependency(package_name, required=False):
    """检查依赖包是否安装"""
    try:
        pkg_version = version(package_name)
        print(f"✓ {package_name} 已安装 (版本: {pkg_version})")
        return True
    except PackageNotFoundError:
        if required:
            print(f"✗ {package_name} 未安装 (必需)")
        else:
            print(f"⚠ {package_name} 未安装 (可选)")
        return False

def main():
    print("=== AI集成功能依赖检查 ===")
    print()
    
    # 核心依赖
    print("核心依赖:")
    core_deps = [
        "django",
        "requests",  # 用于API调用
        "python-dotenv",  # 用于环境变量管理
    ]
    
    for dep in core_deps:
        check_dependency(dep, required=True)
    
    print()
    
    # 可选依赖
    print("可选依赖:")
    optional_deps = [
        "djangorestframework",  # REST API框架
        "pinecone-client",  # Pinecone向量数据库
        "faiss-cpu",  # FAISS向量搜索
        "redis",  # Redis向量存储
        "psycopg2-binary",  # PostgreSQL连接
        "pandas",  # 数据处理
        "numpy",  # 数值计算
    ]
    
    for dep in optional_deps:
        check_dependency(dep, required=False)
    
    print()
    
    # 检查Django项目结构
    print("=== 项目结构检查 ===")
    import os
    
    project_root = os.path.dirname(os.path.abspath(__file__))
    version_dir = os.path.join(project_root, "version1.2-dev")
    
    if os.path.exists(version_dir):
        print(f"✓ 项目目录存在: {version_dir}")
        
        # 检查主要应用目录
        apps = ["credit_app", "agreements", "credit_continuous_dashboard"]
        for app in apps:
            app_path = os.path.join(version_dir, app)
            if os.path.exists(app_path):
                print(f"✓ {app} 应用目录存在")
            else:
                print(f"✗ {app} 应用目录不存在")
    else:
        print(f"✗ 项目目录不存在: {version_dir}")
    
    print()
    print("=== 检查完成 ===")
    print("请根据检查结果安装缺失的依赖包")
    print("对于必需依赖，请使用 pip install 命令安装")
    print("对于可选依赖，根据实际需要安装")

if __name__ == "__main__":
    main()
