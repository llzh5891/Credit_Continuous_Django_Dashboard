"""
Celery任务和Django信号处理
"""

import logging
from django.db.models.signals import post_save
from django.dispatch import receiver
from celery import shared_task

from .models import AgreementPDF
from .services import parse_and_save_agreement

logger = logging.getLogger(__name__)

@shared_task(bind=True, max_retries=3)
def parse_agreement_task(self, agreement_id: int):
    """
    异步解析协议任务
    
    Args:
        agreement_id: 协议ID
    """
    logger.info(f"开始异步解析协议任务: {agreement_id}")
    
    try:
        result = parse_and_save_agreement(agreement_id)
        
        if result['status'] == 'success':
            logger.info(f"异步解析任务完成: {agreement_id}")
        else:
            logger.error(f"异步解析任务失败: {agreement_id}, 结果: {result}")
            
            # 重试
            raise self.retry(exc=Exception(result['message']), countdown=60)
            
    except Exception as e:
        logger.error(f"异步解析任务异常: {agreement_id}, 错误: {str(e)}", exc_info=True)
        
        # 更新状态为错误
        try:
            agreement = AgreementPDF.objects.get(id=agreement_id)
            agreement.parsing_status = 'error'
            agreement.save(update_fields=['parsing_status', 'updated_at'])
        except AgreementPDF.DoesNotExist:
            pass
        
        raise

@receiver(post_save, sender=AgreementPDF)
def trigger_agreement_parsing(sender, instance, created, **kwargs):
    """
    文件上传后触发解析的信号处理
    
    Args:
        sender: 模型类
        instance: 模型实例
        created: 是否新建
    """
    if created and instance.original_file:
        logger.info(f"新协议上传，触发解析: {instance.id} - {instance.file_name}")
        
        # 异步解析
        parse_agreement_task.delay(instance.id)
