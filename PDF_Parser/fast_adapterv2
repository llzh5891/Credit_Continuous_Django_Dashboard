# agreements/parsers/fast_adapter.py
import os
import logging
from typing import Dict, Any

logger = logging.getLogger(__name__)

class FastParserAdapter:
    """
    适配器，用于将FastLoanAgreementParser的输出格式转换为系统期望的格式
    """
    
    def parse_pdf(self, pdf_path: str) -> Dict[str, Any]:
        """
        解析PDF文件并返回标准格式的结果
        
        Args:
            pdf_path: PDF文件路径
            
        Returns:
            包含解析结果的字典
        """
        logger.info(f"开始解析PDF: {pdf_path}")
        
        try:
            # 1. 导入FastLoanAgreementParser
            from .fast_loan_parser import FastLoanAgreementParser
            
            # 2. 初始化解析器
            parser = FastLoanAgreementParser()
            logger.info("FastLoanAgreementParser初始化成功")
            
            # 3. 解析PDF
            logger.info(f"调用FastLoanAgreementParser.parse()")
            raw_result = parser.parse(pdf_path)
            logger.info(f"解析完成: success={raw_result.get('success')}")
            
            # 4. 转换格式
            return self._format_result(raw_result)
            
        except ImportError as e:
            error_msg = f"导入FastLoanAgreementParser失败: {str(e)}"
            logger.error(error_msg)
            return {
                "success": False,
                "error_message": error_msg
            }
        except Exception as e:
            error_msg = f"解析过程中发生错误: {str(e)}"
            logger.error(error_msg)
            import traceback
            logger.error(traceback.format_exc())
            return {
                "success": False,
                "error_message": error_msg
            }
    
    def _format_result(self, raw_result: Dict) -> Dict[str, Any]:
        """
        将原始解析结果转换为标准格式
        """
        if not raw_result.get("success"):
            return {
                "success": False,
                "error_message": raw_result.get("error", "未知错误"),
                "raw_result": raw_result
            }
        
        # 提取关键信息
        borrower_name = raw_result.get("borrower_name", "")
        facility_amount = raw_result.get("facility_amount")
        currency = raw_result.get("currency", "HKD")
        agreement_date = raw_result.get("agreement_date")
        confidence = raw_result.get("confidence", 0.0)
        parsing_time = raw_result.get("parsing_time", 0)
        parsed_text = raw_result.get("parsed_text", "")
        
        # 构建标准格式结果
        formatted_result = {
            "success": True,
            "borrower_name": borrower_name,
            "borrower_confidence": confidence if borrower_name else 0.0,
            "facility_amount": facility_amount,
            "amount_confidence": confidence if facility_amount else 0.0,
            "currency": currency,
            "agreement_date": agreement_date,
            "date_confidence": confidence if agreement_date else 0.0,
            "performance_metrics": {
                "parsing_time_ms": parsing_time * 1000 if parsing_time else 0,
                "text_length": len(parsed_text),
                "extracted_fields": len([v for v in [
                    borrower_name, facility_amount, agreement_date
                ] if v])
            },
            "parsed_text": parsed_text,
            "raw_result": raw_result
        }
        
        # 添加错误信息字段（即使成功也为空）
        formatted_result["error_message"] = ""
        
        return formatted_result


# 可选：添加一个测试函数
def test_adapter():
    """测试适配器功能"""
    adapter = FastParserAdapter()
    
    # 测试一个不存在的文件
    result = adapter.parse_pdf("test_nonexistent.pdf")
    print("测试不存在的文件:", result)
    
    # 可以添加更多测试
    return result


if __name__ == "__main__":
    # 直接运行文件时执行测试
    test_adapter()
    print("FastParserAdapter 测试完成")
