    def test_error_handling(self):
        """测试错误处理"""
        # 测试不存在的文件
        with self.assertRaises(ParserError):
            self.parser.parse("/nonexistent/file.pdf")
        
        # 测试无效的PDF文件
        with tempfile.NamedTemporaryFile(suffix='.pdf', delete=False) as tmp_file:
            tmp_file.write(b'Not a valid PDF')
            tmp_path = tmp_file.name
        
        try:
            with self.assertRaises(PDFExtractionError):
                self.parser.parse(tmp_path)
        finally:
            os.unlink(tmp_path)

class TestAgreementParsingService(TestCase):
    """测试协议解析服务"""
    
    def setUp(self):
        """测试设置"""
        from django.core.files.base import ContentFile
        
        # 创建测试PDF文件
        self.pdf_content = b'%PDF-1.4 fake pdf content\n借款人：测试公司\n金额：HKD 1,000,000.00\n日期：2023-12-31'
        self.pdf_file = ContentFile(self.pdf_content, name='test_agreement.pdf')
    
    def test_parse_agreement(self):
        """测试解析协议"""
        from ..models import AgreementPDF
        
        # 创建测试协议
        agreement = AgreementPDF.objects.create(
            file_name='test.pdf',
            original_file=self.pdf_file,
            parsing_status='uploaded',
            match_status='pending'
        )
        
        # 测试解析
        from ..services import AgreementParsingService
        
        service = AgreementParsingService()
        
        with patch.object(service.parser, 'parse') as mock_parse:
            mock_parse.return_value = {
                'raw_text': '测试文本',
                'borrower_name': '测试公司',
                'borrower_confidence': 0.9,
                'agreement_date': date(2023, 12, 31),
                'date_confidence': 0.8,
                'facility_amount': 1000000.0,
                'amount_confidence': 0.85,
                'currency': 'HKD',
                'currency_confidence': 0.8,
                'overall_confidence': 0.85
            }
            
            result = service.parse_agreement(agreement)
            
            # 验证结果
            self.assertIsNotNone(result)
            self.assertEqual(result['borrower_name'], '测试公司')
            
            # 刷新数据库对象
            agreement.refresh_from_db()
            self.assertEqual(agreement.parsing_status, 'parsed')
            self.assertEqual(agreement.borrower_name, '测试公司')

