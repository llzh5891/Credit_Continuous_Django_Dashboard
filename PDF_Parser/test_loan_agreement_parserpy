class TestLoanAgreementParser(TestCase):
    """测试信贷协议解析器"""
    
    def setUp(self):
        """测试设置"""
        self.parser = LoanAgreementParser()
        self.test_text = """
        信贷协议
        
        本协议由以下双方于2023年12月31日签订：
        
        借款人：ABC科技有限公司
        Borrower: ABC Technology Co., Ltd.
        
        贷款人：XYZ银行有限公司
        Lender: XYZ Bank Limited
        
        融资金额：HKD 10,000,000.00
        Facility Amount: HKD 10,000,000.00
        
        利率：5.5%
        Interest Rate: 5.5% per annum
        
        期限：24个月
        Term: 24 months
        
        本协议自签订之日起生效。
        """
    
    def test_extract_borrower_name(self):
        """测试提取借款人名称"""
        result = self.parser._extract_borrower_name(self.test_text)
        
        self.assertIsNotNone(result["borrower_name"])
        self.assertIn("ABC", result["borrower_name"])
        self.assertGreater(result["borrower_confidence"], 0.6)
    
    def test_extract_agreement_date(self):
        """测试提取协议日期"""
        result = self.parser._extract_agreement_date(self.test_text)
        
        self.assertIsNotNone(result["agreement_date"])
        self.assertEqual(result["agreement_date"], date(2023, 12, 31))
        self.assertGreater(result["date_confidence"], 0.6)
    
    def test_extract_facility_amount(self):
        """测试提取融资金额"""
        result = self.parser._extract_facility_amount(self.test_text)
        
        self.assertIsNotNone(result["facility_amount"])
        self.assertEqual(result["facility_amount"], 10000000.0)
        self.assertEqual(result["currency"], "HKD")
        self.assertGreater(result["amount_confidence"], 0.6)
    
    def test_extract_optional_fields(self):
        """测试提取可选字段"""
        result = self.parser._extract_optional_fields(self.test_text)
        
        self.assertIsNotNone(result["lender_name"])
        self.assertIn("XYZ", result["lender_name"])
        
        self.assertIsNotNone(result["interest_rate"])
        self.assertEqual(result["interest_rate"], 5.5)
        
        self.assertIsNotNone(result["term"])
        self.assertEqual(result["term"], 24)
    
    def test_clean_borrower_name(self):
        """测试清理借款人名称"""
        test_cases = [
            ("ABC科技有限公司", "ABC科技"),
            ("XYZ集团有限公司", "XYZ集团"),
            ("ABC Limited", "ABC"),
            ("XYZ Co., Ltd.", "XYZ Co."),
            ("   ABC公司   ", "ABC"),
        ]
        
        for input_name, expected in test_cases:
            cleaned = self.parser._clean_borrower_name(input_name)
            # 注意：实际清理可能更复杂，这里只是基本测试
            self.assertIsInstance(cleaned, str)
    
    def test_validate_borrower_name(self):
        """测试验证借款人名称"""
        valid_names = ["ABC科技有限公司", "XYZ集团有限公司", "Test Company"]
        invalid_names = ["", "借款人", "123", "A"]
        
        for name in valid_names:
            self.assertTrue(self.parser._validate_borrower_name(name))
        
        for name in invalid_names:
            self.assertFalse(self.parser._validate_borrower_name(name))
    
    def test_parse_date_from_text(self):
        """测试从文本解析日期"""
        from agreement_parser.utils import parse_date_from_text
        
        test_cases = [
            ("2023-12-31", date(2023, 12, 31)),
            ("2023/12/31", date(2023, 12, 31)),
            ("2023年12月31日", date(2023, 12, 31)),
            ("31/12/2023", date(2023, 12, 31)),
            ("December 31, 2023", date(2023, 12, 31)),
            ("invalid date", None),
        ]
        
        for input_text, expected in test_cases:
            result = parse_date_from_text(input_text)
            self.assertEqual(result, expected)
    
    def test_parse_amount_from_text(self):
        """测试从文本解析金额"""
        from agreement_parser.utils import parse_amount_from_text
        
        test_cases = [
            ("1,000,000.00", Decimal("1000000.00")),
            ("1000000", Decimal("1000000")),
            ("1.5", Decimal("1.5")),
            ("invalid", None),
        ]
        
        for input_text, expected in test_cases:
            result = parse_amount_from_text(input_text)
            if expected is None:
                self.assertIsNone(result)
            else:
                self.assertEqual(result, expected)
    
