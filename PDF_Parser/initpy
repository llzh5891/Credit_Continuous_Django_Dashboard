# 快速使用的工厂函数
def create_parser(version: int = 2, config=None, use_ocr: bool = False):
    """
    创建解析器的便捷函数
    
    Args:
        version: 解析器版本，1=基础版，2=增强版
        config: 配置对象
        use_ocr: 是否启用OCR
        
    Returns:
        解析器实例
    """
    if version == 1:
        from .loan_agreement_parser import LoanAgreementParser
        return LoanAgreementParser(config, use_ocr)
    else:
        from .enhanced_loan_parser import EnhancedLoanAgreementParser
        return EnhancedLoanAgreementParser(config, use_ocr)

