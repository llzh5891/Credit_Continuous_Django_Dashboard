def main():
    print("\n" + "="*70)
    print("🚀 开始评估解析器性能")
    print("="*70)
    
    all_results = []
    
    # 评估每个样本
    sample_num = 1
    total_samples = len(expected_results)
    
    for pdf_file, expected in expected_results.items():
        pdf_path = os.path.join(REAL_SAMPLES_DIR, pdf_file)
        
        if not os.path.exists(pdf_path):
            print(f"\n⚠️  跳过: {pdf_file} (文件不存在)")
            continue
        
        result = evaluate_single_pdf(pdf_path, expected, sample_num, total_samples)
        all_results.append(result)
        
        sample_num += 1
    
    # 计算统计
    stats = calculate_statistics(all_results)
    
    # 打印统计
    print_statistics(stats, all_results)
    
    # 生成建议
    generate_recommendations(stats, all_results)
    
    # 保存结果
    results_file = save_results(all_results, stats)
    
    print("\n" + "="*70)
    print("✅ 评估完成!")
    print("="*70)
    
    return all_results, stats, results_file

