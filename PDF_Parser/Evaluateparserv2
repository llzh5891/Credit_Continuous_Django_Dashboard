def generate_recommendations(stats, results):
    """生成改进建议"""
    print(f"\n🔧 改进建议:")
    
    # 检查解析失败
    if stats['failed_parses'] > 0:
        print(f"1. 修复解析崩溃问题 ({stats['failed_parses']} 个样本失败)")
    
    # 找出最差的字段
    worst_field = None
    worst_accuracy = 1.0
    
    for field_key, field_stats in stats['field_accuracy'].items():
        if field_stats['total'] > 0 and field_stats['accuracy'] < worst_accuracy:
            worst_accuracy = field_stats['accuracy']
            worst_field = field_key
    
    if worst_field and worst_accuracy < 0.8:
        field_names = {
            'borrower_name': '借款人名称',
            'agreement_date': '协议日期',
            'facility_amount': '融资金额',
            'currency': '币种',
            'borrowers': '借款人列表',
        }
        
        field_name = field_names.get(worst_field, worst_field)
        print(f"2. 优先优化 {field_name} 提取 (准确率: {worst_accuracy*100:.1f}%)")
        
        # 显示一个失败例子
        for result in results:
            if (result['parse_success'] and 
                worst_field in result['field_results'] and
                not result['field_results'][worst_field].get('match', False)):
                
                exp = result['field_results'][worst_field].get('expected')
                act = result['field_results'][worst_field].get('actual')
                print(f"   示例: {result['file_name']}")
                print(f"     期望: {exp}")
                print(f"     实际: {act}")
                break
    
    # 性能建议
    if stats['average_time'] > 5:
        print(f"3. 优化处理速度 (平均 {stats['average_time']:.1f}秒)")
    
    if stats['successful_parses'] / stats['total_samples'] > 0.8:
        print(f"4. 解析器表现良好，可以增加更多样本优化")
    elif stats['successful_parses'] / stats['total_samples'] > 0.5:
        print(f"4. 需要优化核心解析逻辑")
    else:
        print(f"4. 需要重新设计解析策略")

def save_results(results, stats):
    """保存评估结果"""
    timestamp = datetime.now().strftime('%Y%m%d_%H%M%S')
    results_file = os.path.join(EVALUATION_RESULTS_DIR, f'evaluation_{timestamp}.json')
    
    # 准备保存的数据
    save_data = {
        'evaluation_time': datetime.now().isoformat(),
        'statistics': stats,
        'results': results,
    }
    
    # 转换日期等不可JSON序列化的对象
    def convert_for_json(obj):
        if hasattr(obj, 'isoformat'):
            return obj.isoformat()
        return str(obj)
    
    with open(results_file, 'w', encoding='utf-8') as f:
        json.dump(save_data, f, indent=2, ensure_ascii=False, default=convert_for_json)
    
    print(f"\n💾 详细结果已保存: {results_file}")
    return results_file

