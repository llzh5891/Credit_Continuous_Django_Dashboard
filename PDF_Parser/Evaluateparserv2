def evaluate_single_pdf(pdf_path, expected_data, sample_num, total_samples):
    """评估单个PDF"""
    print(f"\n{'='*60}")
    print(f"📄 样本 {sample_num}/{total_samples}: {os.path.basename(pdf_path)}")
    if 'notes' in expected_data:
        print(f"   📝 备注: {expected_data['notes']}")
    
    file_size = os.path.getsize(pdf_path) / 1024  # KB
    print(f"   📊 文件大小: {file_size:.1f} KB")
    
    result = {
        'file_name': os.path.basename(pdf_path),
        'file_size_kb': round(file_size, 1),
        'parse_success': False,
        'parse_error': None,
        'processing_time': 0,
        'field_results': {},
        'performance_metrics': {},
    }
    
    # 创建解析器
    parser = EnhancedLoanAgreementParser()
    
    # 解析PDF
    start_time = time.time()
    try:
        parse_result = parser.parse(pdf_path)
        elapsed = time.time() - start_time
        
        result['parse_success'] = True
        result['processing_time'] = round(elapsed, 2)
        result['parse_result'] = parse_result
        
        # 提取性能指标
        if 'processing_time_seconds' in parse_result:
            result['performance_metrics']['total_time'] = parse_result['processing_time_seconds']
        if 'processing_mode' in parse_result:
            result['performance_metrics']['mode'] = parse_result['processing_mode']
        
        print(f"   ✅ 解析成功")
        print(f"   ⏱️  处理时间: {elapsed:.2f}秒")
        print(f"   🎯 置信度: {parse_result.get('overall_confidence', 0):.2f}")
        
        # 比较字段
        compare_fields(parse_result, expected_data, result)
        
    except Exception as e:
        elapsed = time.time() - start_time
        result['parse_success'] = False
        result['parse_error'] = str(e)
        result['processing_time'] = round(elapsed, 2)
        
        print(f"   ❌ 解析失败")
        print(f"   ⏱️  失败时间: {elapsed:.2f}秒")
        print(f"   💥 错误: {e}")
    
    return result

def compare_fields(actual_result, expected_data, result_dict):
    """比较字段"""
    fields_to_check = [
        ('borrower_name', '借款人名称'),
        ('agreement_date', '协议日期'),
        ('facility_amount', '融资金额'),
        ('currency', '币种'),
    ]
    
    for field_key, field_name in fields_to_check:
        expected_val = expected_data.get(field_key)
        actual_val = actual_result.get(field_key)
        
        field_result = {
            'expected': expected_val,
            'actual': actual_val,
            'match': False,
            'notes': ''
        }
        
        if expected_val is None:
            field_result['notes'] = '无期望值'
            print(f"   ⏭️  {field_name}: 无期望值")
        
        elif actual_val is None:
            field_result['notes'] = '未提取到'
            print(f"   ❌ {field_name}: 未提取到 (期望: {expected_val})")
        
        else:
            # 特殊处理不同类型的比较
            if field_key == 'agreement_date':
                # 日期比较
                if hasattr(actual_val, 'isoformat'):
                    actual_str = actual_val.isoformat()
                else:
                    actual_str = str(actual_val)
                expected_str = str(expected_val)
                
                is_match = actual_str == expected_str
                display_actual = actual_str
                
            elif field_key == 'facility_amount':
                # 金额比较（允许1%误差）
                try:
                    actual_float = float(actual_val)
                    expected_float = float(expected_val)
                    tolerance = expected_float * 0.01  # 1%误差
                    is_match = abs(actual_float - expected_float) <= tolerance
                    display_actual = f"{actual_float:,.2f}"
                except:
                    is_match = False
                    display_actual = str(actual_val)
            
            else:
                # 字符串比较
                is_match = str(actual_val).strip() == str(expected_val).strip()
                display_actual = str(actual_val)
            
            field_result['match'] = is_match
            
            if is_match:
                print(f"   ✅ {field_name}: {display_actual}")
            else:
                print(f"   ❌ {field_name}: 期望={expected_val}, 实际={display_actual}")
        
        result_dict['field_results'][field_key] = field_result
    
    # 检查多借款人
    expected_borrowers = expected_data.get('borrowers', [])
    actual_borrowers = actual_result.get('borrowers', [])
    
    if expected_borrowers and actual_borrowers:
        # 简单比较：至少有一个匹配
        match_found = False
        for exp_borrower in expected_borrowers:
            for act_borrower in actual_borrowers:
                if exp_borrower in act_borrower or act_borrower in exp_borrower:
                    match_found = True
                    break
            if match_found:
                break
        
        borrowers_result = {
            'expected': expected_borrowers,
            'actual': actual_borrowers,
            'match': match_found
        }
        
        result_dict['field_results']['borrowers'] = borrowers_result
        
        if match_found:
            print(f"   ✅ 借款人列表匹配: {actual_borrowers}")
        else:
            print(f"   ❌ 借款人列表: 期望={expected_borrowers}, 实际={actual_borrowers}")
    elif expected_borrowers and not actual_borrowers:
        print(f"   ❌ 借款人列表: 期望={expected_borrowers}, 实际=未提取到")
    elif actual_borrowers:
        print(f"   📋 提取到借款人列表: {actual_borrowers}")

def calculate_statistics(results):
    """计算统计信息"""
    stats = {
        'total_samples': len(results),
        'successful_parses': 0,
        'failed_parses': 0,
        'average_time': 0,
        'field_accuracy': {},
        'performance_summary': {},
    }
    
    # 初始化字段统计
    field_keys = ['borrower_name', 'agreement_date', 'facility_amount', 'currency', 'borrowers']
    for field in field_keys:
        stats['field_accuracy'][field] = {
            'total': 0,
            'correct': 0,
            'accuracy': 0.0
        }
    
    total_time = 0
    parse_times = []
    
    for result in results:
        if result['parse_success']:
            stats['successful_parses'] += 1
            total_time += result['processing_time']
            parse_times.append(result['processing_time'])
            
            # 统计字段准确率
            for field in field_keys:
                if field in result['field_results']:
                    field_result = result['field_results'][field]
                    stats['field_accuracy'][field]['total'] += 1
                    if field_result.get('match', False):
                        stats['field_accuracy'][field]['correct'] += 1
        else:
            stats['failed_parses'] += 1
    
    # 计算平均值
    if stats['successful_parses'] > 0:
        stats['average_time'] = total_time / stats['successful_parses']
    
    # 计算字段准确率
    for field in field_keys:
        field_stats = stats['field_accuracy'][field]
        if field_stats['total'] > 0:
            field_stats['accuracy'] = field_stats['correct'] / field_stats['total']
    
    # 性能摘要
    if parse_times:
        stats['performance_summary'] = {
            'min_time': min(parse_times),
            'max_time': max(parse_times),
            'avg_time': sum(parse_times) / len(parse_times),
            'total_time': sum(parse_times),
        }
    
    return stats

