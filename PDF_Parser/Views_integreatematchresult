# agreements/views.py
import json
from django.views import View
from django.shortcuts import render, get_object_or_404
from django.http import JsonResponse
from .models import AgreementPDF
from .services import find_potential_customer_matches, link_agreement_to_customer
import logging

logger = logging.getLogger(__name__)

class MatchCustomerView(View):
    """显示客户匹配结果页面"""
    template_name = 'agreements/match_results.html'
    
    def get(self, request, agreement_id):
        try:
            # 获取协议对象
            agreement = get_object_or_404(AgreementPDF, id=agreement_id)
            
            # 获取匹配结果
            results = find_potential_customer_matches(agreement_id)
            
            # 如果服务返回错误
            if 'error' in results:
                logger.error(f"Match error for agreement {agreement_id}: {results['error']}")
                return render(request, self.template_name, {
                    'error': results['error'],
                    'agreement': agreement
                })
            
            # 准备上下文数据
            context = {
                'agreement': results['agreement'],
                'matches': results['matches'],
                'normalized_borrower': results.get('normalized_borrower', ''),
                'json_response': json.dumps(results, indent=2, ensure_ascii=False)
            }
            
            return render(request, self.template_name, context)
            
        except Exception as e:
            logger.exception(f"Error in match_customer view: {str(e)}")
            return render(request, self.template_name, {
                'error': f"系统错误: {str(e)}",
                'agreement_id': agreement_id
            })

class LinkCustomerView(View):
    """处理客户关联请求"""
    
    def post(self, request, agreement_id):
        try:
            customer_id = request.POST.get('customer_id')
            if not customer_id:
                return JsonResponse({
                    'success': False,
                    'message': 'Missing customer ID'
                }, status=400)
            
            success, message = link_agreement_to_customer(agreement_id, customer_id)
            
            return JsonResponse({
                'success': success,
                'message': message
            })
            
        except Exception as e:
            logger.error(f"Link error: {str(e)}")
            return JsonResponse({
                'success': False,
                'message': str(e)
            }, status=500)

class AgreementDetailView(View):
    """协议详情页面"""
    template_name = 'agreements/agreement_detail.html'
    
    def get(self, request, agreement_id):
        agreement = get_object_or_404(AgreementPDF, id=agreement_id)
        return render(request, self.template_name, {
            'agreement': agreement
        })
