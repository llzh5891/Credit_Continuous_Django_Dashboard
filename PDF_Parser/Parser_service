import os
import logging
from django.db import transaction
from django.utils import timezone
from datetime import datetime

logger = logging.getLogger(__name__)


def parse_agreement_pdf(agreement_id: int) -> bool:
    """
    解析PDF协议并保存到数据库
    
    Args:
        agreement_id: AgreementPDF对象的ID
        
    Returns:
        bool: 解析是否成功
    """
    from ..models import AgreementPDF, ParsingLog
    
    try:
        # 获取协议对象
        agreement = AgreementPDF.objects.get(id=agreement_id)
        
        # 更新状态为解析中
        agreement.parsing_status = 'parsing'
        agreement.save(update_fields=['parsing_status'])
        
        logger.info(f"开始解析协议 {agreement_id}: {agreement.file_name}")
        
        # 记录开始时间
        parse_start_time = timezone.now()
        
        # 获取PDF文件路径
        pdf_path = agreement.original_file.path
        if not os.path.exists(pdf_path):
            raise FileNotFoundError(f"PDF文件不存在: {pdf_path}")
        
        # 导入并初始化快速解析器适配器
        try:
            from ..parsers.fast_adapter import FastParserAdapter
            parser = FastParserAdapter()
        except ImportError as e:
            logger.error(f"无法导入FastParserAdapter: {e}")
            raise ImportError("快速解析器适配器未找到，请确保fast_adapter.py存在")
        
        # 解析PDF
        result = parser.parse_pdf(pdf_path)
        
        # 保存解析结果
        with transaction.atomic():
            # 更新核心字段
            if result.get('borrower_name'):
                agreement.borrower_name = result['borrower_name']
                agreement.borrower_confidence = result.get('borrower_confidence', 0.0)
            
            if result.get('facility_amount'):
                agreement.facility_amount = result['facility_amount']
                agreement.currency = result.get('currency', 'HKD')
                agreement.amount_confidence = result.get('amount_confidence', 0.0)
            
            if result.get('agreement_date'):
                agreement.agreement_date = result['agreement_date']
                agreement.date_confidence = result.get('date_confidence', 0.0)
            
            if result.get('parsed_text'):
                agreement.parsed_text = result['parsed_text']
            
            # 保存原始解析结果（用于调试）
            agreement.parsed_data = result.get('raw_result', {})
            
            # 更新状态
            if result.get('success'):
                agreement.parsing_status = 'parsed'
                agreement.parsing_completed_at = timezone.now()
                success = True
                log_level = 'info'
                log_message = f"PDF解析成功"
                
                if result.get('borrower_name'):
                    log_message += f"，借款人: {result['borrower_name']}"
                if result.get('facility_amount'):
                    log_message += f"，金额: {result['facility_amount']} {result.get('currency', 'HKD')}"
                    
            else:
                agreement.parsing_status = 'error'
                success = False
                log_level = 'error'
                log_message = f"PDF解析失败: {result.get('error_message', '未知错误')}"
            
            # 计算解析耗时
            parse_duration = (timezone.now() - parse_start_time).total_seconds()
            agreement.parsing_duration = parse_duration
            agreement.processing_mode = result.get('processing_mode', 'fast_parser')
            
            # 保存更新
            agreement.save()
            
            # 记录解析日志
            ParsingLog.objects.create(
                agreement=agreement,
                log_level=log_level,
                message=log_message,
                details={
                    'parsing_duration': parse_duration,
                    'processing_mode': result.get('processing_mode'),
                    'performance': result.get('performance_metrics', {}),
                    'success': success,
                    'error': result.get('error_message') if not success else None,
                }
            )
        
        logger.info(f"协议 {agreement_id} 解析完成，耗时: {parse_duration:.2f}秒，成功: {success}")
        return success
        
    except AgreementPDF.DoesNotExist:
        logger.error(f"协议 {agreement_id} 不存在")
        return False
        
    except FileNotFoundError as e:
        logger.error(f"PDF文件不存在: {e}")
        
        # 更新状态为错误
        with transaction.atomic():
            agreement.parsing_status = 'error'
            agreement.save(update_fields=['parsing_status'])
            
            ParsingLog.objects.create(
                agreement=agreement,
                log_level='error',
                message=f"PDF文件不存在: {str(e)}"
            )
        return False
        
    except Exception as e:
        logger.error(f"解析协议 {agreement_id} 时发生错误: {str(e)}", exc_info=True)
        
        # 更新状态为错误
        with transaction.atomic():
            if 'agreement' in locals():
                agreement.parsing_status = 'error'
                agreement.save(update_fields=['parsing_status'])
                
                ParsingLog.objects.create(
                    agreement=agreement,
                    log_level='error',
                    message=f"解析错误: {str(e)}"
                )
        
        return False


