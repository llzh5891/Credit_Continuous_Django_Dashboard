            print(f"[parse_service]   解析结果: {result}")
        except Exception as e:
            print(f"[parse_service]   ✗ 解析过程中异常: {e}")
            import traceback
            traceback.print_exc()
            agreement.parsing_status = 'error'
            agreement.save(update_fields=['parsing_status'])
            return False
        
        # 6. 处理解析结果
        print(f"[parse_service] 6. 处理解析结果")
        print(f"[parse_service]   成功: {result.get('success')}")
        print(f"[parse_service]   错误信息: {result.get('error_message')}")
        
        if result.get('success'):
            # 提取数据
            borrower_name = result.get('borrower_name', '')
            facility_amount = result.get('facility_amount')
            currency = result.get('currency', 'HKD')
            agreement_date = result.get('agreement_date')
            
            print(f"[parse_service]   提取的数据:")
            print(f"[parse_service]     借款人: {borrower_name}")
            print(f"[parse_service]     金额: {facility_amount}")
            print(f"[parse_service]     货币: {currency}")
            print(f"[parse_service]     日期: {agreement_date}")
            
            # 保存到数据库
            print(f"[parse_service] 7. 保存到数据库")
            agreement.borrower_name = borrower_name
            agreement.facility_amount = facility_amount
            agreement.currency = currency
            agreement.agreement_date = agreement_date
            agreement.parsing_status = 'parsed'
            agreement.parsed_data = result
            
            with transaction.atomic():
                agreement.save()
            
            print(f"[parse_service]   ✓ 保存成功")
            return True
        else:
            print(f"[parse_service]   ✗ 解析失败: {result.get('error_message')}")
            agreement.parsing_status = 'error'
            agreement.save(update_fields=['parsing_status'])
            return False
            
    except Exception as e:
        print(f"[parse_service] ✗ 解析过程异常: {e}")
        import traceback
        traceback.print_exc()
        
        # 尝试保存错误状态
        try:
            agreement.parsing_status = 'error'
            agreement.save(update_fields=['parsing_status'])
        except:
            pass
        
        return False
    finally:
        print(f"[parse_service] 解析完成")
        print(f"{'='*60}\n")


