def parse_agreement_pdf(agreement_id: int) -> bool:
    """
    解析PDF协议并保存到数据库
    """
    from ..models import AgreementPDF, ParsingLog
    
    # 2. 在函数开始时添加日志
    logger.info(f"=== 开始解析协议 ID: {agreement_id} ===")
    
    try:
        # 获取协议对象
        agreement = AgreementPDF.objects.get(id=agreement_id)
        logger.info(f"1. 找到协议: {agreement.file_name}")
        
        # 更新状态为解析中
        agreement.parsing_status = 'parsing'
        agreement.save(update_fields=['parsing_status'])
        logger.info(f"2. 更新状态为: parsing")
        
        # 获取PDF文件路径
        pdf_path = agreement.original_file.path
        logger.info(f"3. PDF路径: {pdf_path}")
        logger.info(f"4. 文件存在: {os.path.exists(pdf_path)}")
        
        if not os.path.exists(pdf_path):
            error_msg = f"PDF文件不存在: {pdf_path}"
            logger.error(error_msg)
            raise FileNotFoundError(error_msg)
        
        # 3. 尝试导入快速解析器适配器
        logger.info("5. 导入FastParserAdapter...")
        try:
            from ..parsers.fast_adapter import FastParserAdapter
            logger.info("6. FastParserAdapter导入成功")
        except ImportError as e:
            logger.error(f"导入FastParserAdapter失败: {e}")
            raise ImportError(f"快速解析器适配器未找到: {e}")
        
        # 初始化解析器
        parser = FastParserAdapter()
        logger.info(f"7. 解析器初始化完成")
        
        # 4. 解析PDF
        logger.info("8. 开始解析PDF...")
        parse_start = timezone.now()
        result = parser.parse_pdf(pdf_path)
        parse_duration = (timezone.now() - parse_start).total_seconds()
        
        logger.info(f"9. 解析完成，耗时: {parse_duration:.2f}秒")
        logger.info(f"   成功: {result.get('success')}")
        logger.info(f"   错误: {result.get('error_message', '无')}")
        logger.info(f"   借款人: {result.get('borrower_name', '未提取')}")
        logger.info(f"   金额: {result.get('facility_amount', '未提取')}")
        logger.info(f"   币种: {result.get('currency', '未提取')}")
        logger.info(f"   日期: {result.get('agreement_date', '未提取')}")
        
        # 5. 保存解析结果
        with transaction.atomic():
            # 更新核心字段
            if result.get('borrower_name'):
                agreement.borrower_name = result['borrower_name']
                agreement.borrower_confidence = result.get('borrower_confidence', 0.0)
                logger.info(f"10. 保存借款人: {result['borrower_name']}")
            
            if result.get('facility_amount'):
                agreement.facility_amount = result['facility_amount']
                agreement.currency = result.get('currency', 'HKD')
                agreement.amount_confidence = result.get('amount_confidence', 0.0)
                logger.info(f"11. 保存金额: {result['facility_amount']} {result.get('currency', 'HKD')}")
            
            if result.get('agreement_date'):
                agreement.agreement_date = result['agreement_date']
                agreement.date_confidence = result.get('date_confidence', 0.0)
                logger.info(f"12. 保存日期: {result['agreement_date']}")
            
            if result.get('parsed_text'):
                agreement.parsed_text = result['parsed_text']
            
            # 保存原始解析结果
            agreement.parsed_data = result.get('raw_result', {})
            
            # 更新状态
            if result.get('success'):
                agreement.parsing_status = 'parsed'
                agreement.parsing_completed_at = timezone.now()
                success = True
                log_level = 'info'
                log_message = f"PDF解析成功"
                
                if result.get('borrower_name'):
                    log_message += f"，借款人: {result['borrower_name']}"
                if result.get('facility_amount'):
                    log_message += f"，金额: {result['facility_amount']} {result.get('currency', 'HKD')}"
                    
                logger.info(f"13. 解析成功: {log_message}")
            else:
                agreement.parsing_status = 'error'
                success = False
                log_level = 'error'
                error_msg = result.get('error_message', '未知错误')
                log_message = f"PDF解析失败: {error_msg}"
                logger.error(f"13. 解析失败: {log_message}")
            
            # 计算解析耗时
            agreement.parsing_duration = parse_duration
            agreement.processing_mode = result.get('processing_mode', 'fast_parser')
            
            # 保存更新
            agreement.save()
            logger.info(f"14. 数据库记录已保存")
            
            # 记录解析日志
            ParsingLog.objects.create(
                agreement=agreement,
                log_level=log_level,
                message=log_message,
                details={
                    'parsing_duration': parse_duration,
                    'processing_mode': result.get('processing_mode'),
                    'performance': result.get('performance_metrics', {}),
                    'success': success,
                    'error': result.get('error_message') if not success else None,
                }
            )
            logger.info(f"15. 日志记录已创建")
        
        logger.info(f"16. 协议 {agreement_id} 解析完成，成功: {success}")
        return success
        
    except AgreementPDF.DoesNotExist:
        logger.error(f"协议 {agreement_id} 不存在")
        return False
        
    except FileNotFoundError as e:
        logger.error(f"PDF文件不存在: {e}")
        
        # 更新状态为错误
        with transaction.atomic():
            agreement.parsing_status = 'error'
            agreement.save(update_fields=['parsing_status'])
            
            ParsingLog.objects.create(
                agreement=agreement,
                log_level='error',
                message=f"PDF文件不存在: {str(e)}"
            )
        return False
        
    except Exception as e:
        logger.error(f"解析协议 {agreement_id} 时发生未预期错误: {str(e)}", exc_info=True)
        
        # 更新状态为错误
        with transaction.atomic():
            if 'agreement' in locals():
                agreement.parsing_status = 'error'
                agreement.save(update_fields=['parsing_status'])
                
                ParsingLog.objects.create(
                    agreement=agreement,
                    log_level='error',
                    message=f"解析错误: {str(e)}"
                )
        
        return False
