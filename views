def match_customer(agreement):
    """
    自动匹配客户
    """
    if not agreement.borrower_name:
        agreement.match_status = 'unmatched'
        agreement.save()
        return
    
    # 查找匹配的客户
    customers = agreement.find_matching_customer()
    
    if not customers:
        agreement.match_status = 'unmatched'
        agreement.save()
        return
    
    if len(customers) == 1:
        # 唯一匹配
        agreement.customer = customers[0]
        agreement.match_status = 'matched'
        agreement.match_type = 'customer_name'  # 或 'master_group_name'
        agreement.match_confidence = 0.9
        agreement.save()
        
        # 记录匹配
        ParsingLog.objects.create(
            agreement=agreement,
            log_level='info',
            message=f'Matched with customer: {customers[0].name}'
        )
    else:
        # 多个匹配，需要人工审核
        agreement.match_status = 'manual_review'
        agreement.match_confidence = 0.5
        
        # 保存候选客户
        candidate_data = []
        for customer in customers:
            candidate_data.append({
                'customer_id': customer.customer_id,
                'name': customer.name,
                'master_group_name': customer.master_group_name,
            })
        agreement.candidate_customers = candidate_data
        agreement.save()
        
        ParsingLog.objects.create(
            agreement=agreement,
            log_level='warning',
            message=f'Multiple matches found: {len(customers)} customers'
        )


