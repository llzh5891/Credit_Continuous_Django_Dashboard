class AgreementListView(LoginRequiredMixin, ListView):
    """协议列表页面"""
    model = AgreementPDF
    template_name = 'agreements/list.html'
    context_object_name = 'agreements'
    paginate_by = 20
    
    def get_queryset(self):
        queryset = super().get_queryset().select_related('customer')
        
        # 搜索功能
        search_query = self.request.GET.get('search', '').strip()
        if search_query:
            queryset = queryset.filter(
                Q(file_name__icontains=search_query) |
                Q(borrower_name__icontains=search_query) |
                Q(customer__name__icontains=search_query) |
                Q(customer__customer_id__icontains=search_query)
            )
        
        # 状态过滤
        parsing_status = self.request.GET.get('parsing_status', '')
        if parsing_status:
            queryset = queryset.filter(parsing_status=parsing_status)
        
        match_status = self.request.GET.get('match_status', '')
        if match_status:
            queryset = queryset.filter(match_status=match_status)
        
        return queryset.order_by('-uploaded_at')
    
    def get_context_data(self, **kwargs):
        context = super().get_context_data(**kwargs)
        
        # 状态统计
        status_stats = AgreementPDF.objects.values('parsing_status').annotate(
            count=Count('id')
        )
        match_stats = AgreementPDF.objects.values('match_status').annotate(
            count=Count('id')
        )
        
        context.update({
            'parsing_status_choices': dict(AgreementPDF.PARSING_STATUS_CHOICES),
            'match_status_choices': dict(AgreementPDF.MATCH_STATUS_CHOICES),
            'status_stats': {item['parsing_status']: item['count'] for item in status_stats},
            'match_stats': {item['match_status']: item['count'] for item in match_stats},
            'search_query': self.request.GET.get('search', ''),
        })
        return context


class AgreementUploadView(LoginRequiredMixin, CreateView):
    """上传PDF页面"""
    model = AgreementPDF
    form_class = AgreementUploadForm
    template_name = 'agreements/upload.html'
    success_url = reverse_lazy('agreements:list')
    
    def get_form_kwargs(self):
        kwargs = super().get_form_kwargs()
        return kwargs
    
    def form_valid(self, form):
        form.instance.parsing_status = 'uploaded'
        form.instance.match_status = 'pending'
        
        # 这里可以添加上传者的信息
        if self.request.user.is_authenticated:
            form.instance.uploaded_by = self.request.user.username
        
        response = super().form_valid(form)
        
        # 启动解析任务（这里可以调用你的解析函数）
        # parse_agreement.delay(self.object.id)
        
        # 简单解析文件名（实际项目中应该用解析器）
        self.extract_from_filename(self.object)
        
        messages.success(
            self.request, 
            f'PDF uploaded successfully! File: {form.instance.file_name}'
        )
        return response
    
    def extract_from_filename(self, agreement):
        """
        简单解析文件名提取信息
        实际项目中应该用PDF解析器
        """
        filename = agreement.file_name or ''
        
        # 这里添加你的文件名解析逻辑
        # 例如: "CustomerName_20240101_1000000.pdf"
        if '_' in filename:
            parts = filename.replace('.pdf', '').replace('.PDF', '').split('_')
            if len(parts) >= 3:
                agreement.borrower_name = parts[0]
                try:
                    # 假设第二部分是日期
                    date_str = parts[1]
                    if len(date_str) == 8 and date_str.isdigit():
                        from datetime import datetime
                        date_obj = datetime.strptime(date_str, '%Y%m%d').date()
                        agreement.agreement_date = date_obj
                except:
                    pass
                
                try:
                    # 假设第三部分是金额
                    amount_str = parts[2]
                    agreement.facility_amount = Decimal(amount_str)
                except:
                    pass
        
        agreement.parsing_status = 'parsed'
        agreement.save()
    
    def get_context_data(self, **kwargs):
        context = super().get_context_data(**kwargs)
        context['dashboard_url'] = reverse_lazy('agreements:dashboard')
        context['list_url'] = reverse_lazy('agreements:list')
        return context


class AgreementDetailView(LoginRequiredMixin, DetailView):
    """协议详情页面"""
    model = AgreementPDF
    template_name = 'agreements/detail.html'
    context_object_name = 'agreement'
    
    def get_context_data(self, **kwargs):
        context = super().get_context_data(**kwargs)
        
        # 获取解析日志
        context['parsing_logs'] = self.object.parsing_logs.all().order_by('-created_at')
        
        # 获取候选客户（用于匹配）
        if self.object.candidate_customers:
            try:
                candidate_ids = [c.get('customer_id') for c in self.object.candidate_customers if c.get('customer_id')]
                if candidate_ids:
                    context['candidates'] = Customer.objects.filter(customer_id__in=candidate_ids)
            except:
                context['candidates'] = Customer.objects.none()
        
        return context


class ManualMatchView(LoginRequiredMixin, View):
    """手动匹配界面"""
    def get(self, request, pk):
        agreement = get_object_or_404(AgreementPDF, pk=pk)
        
        # 查找可能的客户匹配
        possible_customers = []
        if agreement.borrower_name:
            # 查找匹配的客户
            possible_customers = Customer.objects.filter(
                Q(name__icontains=agreement.borrower_name) |
                Q(master_group_name__icontains=agreement.borrower_name)
            ).distinct()[:10]  # 限制显示10个
        
        # 获取所有客户（用于下拉列表）
        all_customers = Customer.objects.all().order_by('name')[:100]  # 限制数量
        
        context = {
            'agreement': agreement,
            'possible_customers': possible_customers,
            'all_customers': all_customers,
        }
        return render(request, 'agreements/manual_match.html', context)
    
    def post(self, request, pk):
        agreement = get_object_or_404(AgreementPDF, pk=pk)
        customer_id = request.POST.get('customer_id')
        
        if customer_id:
            try:
                customer = Customer.objects.get(id=customer_id)
                agreement.customer = customer
                agreement.match_status = 'matched'
                agreement.match_type = 'manual'
                agreement.match_confidence = 1.0
                agreement.is_manually_verified = True
                agreement.verified_by = request.user.username
                agreement.verified_at = timezone.now()
                agreement.save()
                
                messages.success(request, f'Successfully matched with customer: {customer.name}')
            except Customer.DoesNotExist:
                messages.error(request, 'Customer not found')
        else:
            agreement.customer = None
            agreement.match_status = 'unmatched'
            agreement.save()
            messages.info(request, 'Marked as unmatched')
        
        return redirect('agreements:detail', pk=agreement.pk)


# ========== API 视图 ==========
class UploadAPIView(LoginRequiredMixin, View):
    """AJAX上传API"""
    def post(self, request):
        if not request.FILES.get('pdf_file'):
            return JsonResponse({'error': 'No file uploaded'}, status=400)
        
        pdf_file = request.FILES['pdf_file']
        
        # 检查文件类型
        if not pdf_file.name.lower().endswith('.pdf'):
            return JsonResponse({'error': 'Only PDF files are allowed'}, status=400)
        
        # 检查文件大小
        if pdf_file.size > 10 * 1024 * 1024:  # 10MB
            return JsonResponse({'error': 'File size must be less than 10MB'}, status=400)
        
        # 保存文件
        agreement = AgreementPDF(
            original_file=pdf_file,
            parsing_status='uploaded',
            match_status='pending'
        )
        
        if request.user.is_authenticated:
            agreement.uploaded_by = request.user.username
        
        agreement.save()
        
        return JsonResponse({
            'success': True,
            'id': str(agreement.id),
            'filename': agreement.file_name,
            'upload_time': agreement.uploaded_at.isoformat(),
        })


