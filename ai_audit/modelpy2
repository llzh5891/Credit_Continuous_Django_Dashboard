import uuid
from django.db import models
from django.utils import timezone


class TestLogic(models.Model):
    """AI-generated audit test logic model"""
    
    test_id = models.UUIDField(
        primary_key=True,
        default=uuid.uuid4,
        editable=False,
        verbose_name='Test ID'
    )
    
    test_version = models.IntegerField(
        default=1,
        verbose_name='Test Version'
    )
    
    test_name = models.CharField(
        max_length=200,
        verbose_name='Test Name'
    )
    
    test_description = models.TextField(
        null=True,
        blank=True,
        verbose_name='Test Description'
    )
    
    column_to_use = models.CharField(
        max_length=100,
        verbose_name='Column to Use'
    )
    
    objectives = models.JSONField(
        default=list,
        null=True,
        blank=True,
        verbose_name='Objectives'
    )
    
    how_to_test = models.JSONField(
        default=list,
        null=True,
        blank=True,
        verbose_name='How to Test'
    )
    
    exceptions = models.JSONField(
        default=list,
        null=True,
        blank=True,
        verbose_name='Exception Rules'
    )
    
    evidence = models.JSONField(
        default=list,
        null=True,
        blank=True,
        verbose_name='Evidence Required'
    )
    
    test_logic = models.TextField(
        null=True,
        blank=True,
        verbose_name='Original Test Logic'
    )
    
    ai_rationale = models.TextField(
        null=True,
        blank=True,
        verbose_name='AI Rationale'
    )
    
    test_logic_publish_date = models.DateTimeField(
        default=timezone.now,
        verbose_name='Publish Date'
    )
    
    STATUS_CHOICES = [
        ('pending', 'Pending'),
        ('accepted', 'Accepted'),
        ('dropped', 'Dropped'),
        ('active', 'Active'),
        ('inactive', 'Inactive'),
    ]
    
    status = models.CharField(
        max_length=20,
        choices=STATUS_CHOICES,
        default='pending',
        verbose_name='Status'
    )
    
    model_version = models.CharField(
        max_length=50,
        null=True,
        blank=True,
        verbose_name='Model Version'
    )
    
    created_at = models.DateTimeField(
        auto_now_add=True,
        verbose_name='Created At'
    )
    
    updated_at = models.DateTimeField(
        auto_now=True,
        verbose_name='Updated At'
    )
    
    class Meta:
        db_table = 'ai_audit_test_logic'
        verbose_name = 'Test Logic'
        verbose_name_plural = 'Test Logic'
        unique_together = ('test_id', 'test_version')
    
    def __str__(self):
        return f"{self.test_name} (v{self.test_version})"


class AuditException(models.Model):
    """Audit exception model"""
    
    exception_id = models.UUIDField(
        primary_key=True,
        default=uuid.uuid4,
        editable=False,
        verbose_name='Exception ID'
    )
    
    test = models.ForeignKey(
        TestLogic,
        on_delete=models.CASCADE,
        related_name='audit_exceptions',
        verbose_name='Test'
    )
    
    test_version = models.IntegerField(
        verbose_name='Test Version'
    )
    
    ENTITY_TYPE_CHOICES = [
        ('Customer', 'Customer'),
        ('CreditApplication', 'Credit Application'),
        ('Facility', 'Facility'),
        ('AgreementPDF', 'Agreement PDF'),
    ]
    
    entity_type = models.CharField(
        max_length=50,
        choices=ENTITY_TYPE_CHOICES,
        verbose_name='Entity Type'
    )
    
    entity_id = models.CharField(
        max_length=100,
        verbose_name='Entity ID'
    )
    
    exception_details = models.TextField(
        verbose_name='Exception Details'
    )
    
    STATUS_CHOICES = [
        ('detected', 'Detected'),
        ('recognized', 'Recognized'),
        ('investigated', 'Investigated'),
        ('resolved', 'Resolved'),
        ('false_positive', 'False Positive'),
    ]
    
    status = models.CharField(
        max_length=20,
        choices=STATUS_CHOICES,
        default='detected',
        verbose_name='Status'
    )
    
    created_at = models.DateTimeField(
        auto_now_add=True,
        verbose_name='Created At'
    )
    
    updated_at = models.DateTimeField(
        auto_now=True,
        verbose_name='Updated At'
    )
    
    class Meta:
        db_table = 'ai_audit_exception'
        verbose_name = 'Audit Exception'
        verbose_name_plural = 'Audit Exceptions'
        # Fixed: 使用 indexes 替代 index_together
        indexes = [
            models.Index(fields=['test', 'test_version']),
        ]
    
    def __str__(self):
        return f"Exception v{self.test_version}: {self.entity_type} - {self.entity_id}"


class Feedback(models.Model):
    """User feedback model for test improvement"""
    
    id = models.AutoField(primary_key=True)
    
    test = models.ForeignKey(
        TestLogic,
        on_delete=models.CASCADE,
        related_name='feedbacks',
        verbose_name='Test'
    )
    
    exception = models.ForeignKey(
        AuditException,
        on_delete=models.CASCADE,
        related_name='feedbacks',
        verbose_name='Exception'
    )
    
    user_id = models.CharField(
        max_length=100,
        verbose_name='User ID'
    )
    
    feedback_content = models.TextField(
        verbose_name='Feedback Content'
    )
    
    FEEDBACK_TYPE_CHOICES = [
        ('false_positive', 'False Positive'),
        ('suggestion', 'Suggestion'),
        ('bug', 'Bug'),
    ]
    
    feedback_type = models.CharField(
        max_length=20,
        choices=FEEDBACK_TYPE_CHOICES,
        default='false_positive',
        verbose_name='Feedback Type'
    )
    
    PROCESS_STATUS_CHOICES = [
        ('pending', 'Pending'),
        ('processed', 'Processed'),
    ]
    
    process_status = models.CharField(
        max_length=20,
        choices=PROCESS_STATUS_CHOICES,
        default='pending',
        verbose_name='Process Status'
    )
    
    feedback_date = models.DateTimeField(
        default=timezone.now,
        verbose_name='Feedback Date'
    )
    
    created_at = models.DateTimeField(
        auto_now_add=True,
        verbose_name='Created At'
    )
    
    updated_at = models.DateTimeField(
        auto_now=True,
        verbose_name='Updated At'
    )
    
    class Meta:
        db_table = 'ai_audit_feedback'
        verbose_name = 'Feedback'
        verbose_name_plural = 'Feedback'
    
    def __str__(self):
        return f"Feedback: {self.user_id} - {self.feedback_type}"
