@csrf_exempt
def drop_test(request):
    """Drop test with reason"""
    if request.method == 'POST':
        data = json.loads(request.body)
        test_id = data.get('test_id')
        reason = data.get('reason', '')
        
        try:
            test = TestLogic.objects.get(test_id=test_id)
            test.status = 'dropped'
            test.test_description = f"{test.test_description or ''}\n\nDropped Reason: {reason}".strip()
            test.save()
            return JsonResponse({'success': True})
        except TestLogic.DoesNotExist:
            return JsonResponse({'success': False, 'error': 'Test not found'})
        except Exception as e:
            return JsonResponse({'success': False, 'error': str(e)})
    
    return JsonResponse({'success': False, 'error': 'Invalid request'})


def generate_tests(request):
    """Generate test logic and create actual exception records"""
    try:
        # 获取实际数据样本
        customers = list(Customer.objects.all()[:5].values())
        credit_applications = list(CreditApplication.objects.all()[:5].values())
        facilities = list(Facility.objects.all()[:5].values())
        agreements = list(AgreementPDF.objects.all()[:5].values())
        
        # 转换不可序列化对象
        def convert_objects(data):
            from datetime import date, datetime
            from decimal import Decimal
            
            for item in data:
                for key, value in item.items():
                    if value is None:
                        continue
                    if hasattr(value, 'hex') and hasattr(value, 'fields'):
                        item[key] = str(value)
                    elif isinstance(value, date) and not isinstance(value, datetime):
                        item[key] = value.isoformat()
                    elif isinstance(value, datetime):
                        item[key] = value.isoformat()
                    elif isinstance(value, Decimal):
                        item[key] = str(value)
            return data
        
        customers = convert_objects(customers)
        credit_applications = convert_objects(credit_applications)
        facilities = convert_objects(facilities)
        agreements = convert_objects(agreements)
        
        sample_data = {
            'customers': customers,
            'credit_applications': credit_applications,
            'facilities': facilities,
            'agreements': agreements
        }
        
        # 调用AI API生成测试逻辑
        api = get_api_instance()
        response = api.generate_test_logic(sample_data)
        
        if isinstance(response, str):
            try:
                response = json.loads(response)
            except json.JSONDecodeError:
                return HttpResponse("Error: Invalid JSON response")
        
        if response:
            objectives = response.get('objective', [])
            how_to_test = response.get('how to test', [])
            exceptions_data = response.get('exception', [])
            evidence = response.get('evidence', [])
            
            test_rationale = '\n'.join(objectives) if objectives else "No objectives"
            test_content = json.dumps(response, indent=2)
            
            test_id = generate_test_id()
            test_version = 1
            
            # 创建测试逻辑记录
            test = TestLogic.objects.create(
                test_id=test_id,
                test_version=test_version,
                test_name=f"Audit Test {test_id}",
                test_description="AI-generated audit test",
                column_to_use="Multiple columns",
                objectives=objectives,
                how_to_test=how_to_test,
                exceptions=exceptions_data,
                evidence=evidence,
                test_logic=test_content,
                ai_rationale=test_rationale,
                model_version="GPT-5",
                status='pending'
            )
            
            # 确保创建异常记录
            print(f"DEBUG: Creating {len(exceptions_data)} exceptions for test {test.test_id}")
            
            for i, exception_rule in enumerate(exceptions_data):
                entity_type = 'Customer'
                entity_id = str(uuid.uuid4())
                
                # 如果有实际客户数据，使用实际客户ID
                all_customers = list(Customer.objects.all())
                if all_customers:
                    customer = all_customers[i % len(all_customers)]
                    entity_id = str(customer.customer_id)
                
                # 创建异常记录
                exception = AuditException.objects.create(
                    test=test,
                    test_version=test_version,
                    entity_type=entity_type,
                    entity_id=entity_id,
                    exception_details=f"Exception detected: {exception_rule}"
                )
                print(f"DEBUG: Created exception {exception.exception_id}")
            
            # 验证创建结果
            created_exceptions = AuditException.objects.filter(test=test)
            print(f"DEBUG: Total exceptions created: {created_exceptions.count()}")
            
        else:
            return HttpResponse("API call failed")
        
    except Exception as e:
        print(f"DEBUG: Error creating test: {str(e)}")
        return HttpResponse(f"Error: {str(e)}")
    
    return redirect('ai_audit:dashboard')
